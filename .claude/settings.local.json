{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(test:*)",
      "Bash(composer update:*)",
      "Bash(php:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(composer show:*)",
      "Bash(npm outdated)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(git checkout:*)",
      "Bash(timeout 10s npm run dev)",
      "Bash(git push:*)",
      "mcp__laravel-boost__database-schema",
      "mcp__laravel-boost__tinker",
      "mcp__laravel-boost__application-info",
      "mcp__laravel-boost__list-routes",
      "Bash(./vendor/bin/pint:*)",
      "Bash(done)",
      "Bash(find:*)",
      "mcp__laravel-boost__read-log-entries",
      "mcp__laravel-boost__browser-logs",
      "Bash(docker --version:*)",
      "Bash(docker-compose --version:*)",
      "Bash(./vendor/bin/sail up:*)",
      "Bash(./vendor/bin/sail logs:*)",
      "Bash(./vendor/bin/sail artisan:*)",
      "mcp__laravel-boost__last-error",
      "Bash(curl:*)",
      "Bash(cat:*)"
    ],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ]
}
